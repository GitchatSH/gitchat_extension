{
  "name": "top-github-trending",
  "displayName": "Top GitHub Trending Repo & People",
  "description": "Discover trending GitHub repos and developers, connect with devs, and chat — all without leaving the editor.",
  "version": "1.5.2",
  "publisher": "GitstarAI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitstarAI/top-github-trending-repo-and-people"
  },
  "homepage": "https://gitstar.ai",
  "qna": "https://github.com/GitstarAI/top-github-trending-repo-and-people/issues",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "github",
    "trending",
    "repositories",
    "developers",
    "social",
    "collaboration",
    "chat",
    "open-source",
    "cursor",
    "windsurf",
    "networking",
    "messaging",
    "community"
  ],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:trending.welcome",
    "onView:trending.trendingRepos",
    "onView:trending.trendingPeople",
    "onView:trending.feed",
    "onView:trending.chatPanel",
    "onView:trending.whoToFollow",
    "onView:trending.myRepos",
    "onCommand:trending.signIn",
    "onCommand:trending.search",
    "onCommand:trending.browseTrendingRepos",
    "onCommand:trending.browseTrendingPeople",
    "onCommand:trending.openFeed",
    "onCommand:trending.openInbox",
    "onCommand:trending.openNotifications",
    "onCommand:trending.messageUser",
    "onCommand:trending.createGroup"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsWelcome": [
      {
        "view": "trending.chatPanel",
        "contents": "Welcome to Gitstar! Sign in with GitHub to see your friends and start chatting.\n[Sign In with GitHub](command:trending.signIn)",
        "when": "!trending.isSignedIn"
      },
      {
        "view": "trending.myRepos",
        "contents": "Sign in to see your repositories.\n[Sign In with GitHub](command:trending.signIn)",
        "when": "!trending.isSignedIn"
      }
    ],
    "commands": [
      {
        "command": "trending.signIn",
        "title": "Sign In with GitHub",
        "icon": "$(sign-in)",
        "category": "Trending"
      },
      {
        "command": "trending.signOut",
        "title": "Sign Out",
        "icon": "$(sign-out)",
        "category": "Trending"
      },
      {
        "command": "trending.browseTrendingRepos",
        "title": "Browse Trending Repos",
        "category": "Trending",
        "icon": "$(flame)"
      },
      {
        "command": "trending.browseTrendingPeople",
        "title": "Browse Trending People",
        "category": "Trending",
        "icon": "$(person)"
      },
      {
        "command": "trending.openFeed",
        "title": "Open Feed",
        "category": "Trending",
        "icon": "$(rss)"
      },
      {
        "command": "trending.openInbox",
        "title": "Open Inbox",
        "category": "Trending",
        "icon": "$(mail)"
      },
      {
        "command": "trending.openNotifications",
        "title": "Open Notifications",
        "category": "Trending",
        "icon": "$(bell)"
      },
      {
        "command": "trending.search",
        "title": "Search",
        "category": "Trending",
        "icon": "$(search)"
      },
      {
        "command": "trending.viewMyProfile",
        "title": "View My Profile",
        "category": "Trending"
      },
      {
        "command": "trending.messageUser",
        "title": "Message @user",
        "icon": "$(comment-discussion)",
        "category": "Trending"
      },
      {
        "command": "trending.friends.search",
        "title": "Search Friends to Chat",
        "icon": "$(edit)",
        "category": "Trending"
      },
      {
        "command": "trending.friends.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "trending.myRepos.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "trending.trendingRepos.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "trending.trendingPeople.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "trending.feed.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "trending.inbox.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "trending.notifications.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "trending.notifications.markAllRead",
        "title": "Mark All as Read",
        "icon": "$(check-all)"
      },
      {
        "command": "trending.starRepo",
        "title": "Star Repo",
        "icon": "$(star-full)"
      },
      {
        "command": "trending.unstarRepo",
        "title": "Unstar Repo",
        "icon": "$(star-empty)"
      },
      {
        "command": "trending.followUser",
        "title": "Follow",
        "icon": "$(person-add)"
      },
      {
        "command": "trending.unfollowUser",
        "title": "Unfollow",
        "icon": "$(person)"
      },
      {
        "command": "trending.likeEvent",
        "title": "Like",
        "icon": "$(heart)"
      },
      {
        "command": "trending.openOnGithub",
        "title": "Open on GitHub",
        "icon": "$(link-external)"
      },
      {
        "command": "trending.viewRepoDetail",
        "title": "View Repo Detail"
      },
      {
        "command": "trending.viewProfile",
        "title": "View Profile"
      },
      {
        "command": "trending.inbox.pinConversation",
        "title": "Pin Conversation",
        "icon": "$(pin)"
      },
      {
        "command": "trending.inbox.unpinConversation",
        "title": "Unpin Conversation",
        "icon": "$(pinned)"
      },
      {
        "command": "trending.inbox.markRead",
        "title": "Mark as Read",
        "icon": "$(check)"
      },
      {
        "command": "trending.inbox.deleteConversation",
        "title": "Delete Conversation",
        "icon": "$(trash)"
      },
      {
        "command": "trending.createGroup",
        "title": "Create Group Chat",
        "icon": "$(organization)",
        "category": "Trending"
      },
      {
        "command": "trending.openChat",
        "title": "Open Chat"
      },
      {
        "command": "trending.copyInviteLink",
        "title": "Copy Invite Link",
        "icon": "$(link)",
        "category": "Trending"
      },
      {
        "command": "trending.copyProfileBadge",
        "title": "Copy Profile Badge for README",
        "icon": "$(shield)",
        "category": "Trending"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trendingSidebar",
          "title": "Explore",
          "icon": "media/sidebar-icon.svg"
        },
        {
          "id": "chatSidebar",
          "title": "Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "trendingSidebar": [
        {
          "id": "trending.welcome",
          "name": "Welcome",
          "type": "webview",
          "visibility": "visible",
          "when": "!trending.isSignedIn"
        },
        {
          "id": "trending.feed",
          "name": "For You",
          "type": "webview",
          "visibility": "visible",
          "when": "trending.isSignedIn"
        },
        {
          "id": "trending.trendingRepos",
          "name": "Trending Repos",
          "type": "webview",
          "visibility": "visible",
          "when": "trending.isSignedIn"
        },
        {
          "id": "trending.trendingPeople",
          "name": "Trending People",
          "type": "webview",
          "visibility": "visible",
          "when": "trending.isSignedIn"
        },
        {
          "id": "trending.whoToFollow",
          "name": "Who to Follow",
          "type": "webview",
          "visibility": "collapsed",
          "when": "trending.isSignedIn"
        },
        {
          "id": "trending.myRepos",
          "name": "My Repos",
          "visibility": "collapsed",
          "when": "trending.isSignedIn"
        }
      ],
      "chatSidebar": [
        {
          "id": "trending.chatPanel",
          "name": "Messages",
          "type": "webview",
          "visibility": "visible",
          "when": "trending.isSignedIn"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "trending.signIn",
          "when": "view == trending.trendingRepos && !trending.isSignedIn",
          "group": "navigation@0"
        },
        {
          "command": "trending.signOut",
          "when": "view == trending.trendingRepos && trending.isSignedIn",
          "group": "navigation@0"
        },
        {
          "command": "trending.signIn",
          "when": "view == trending.trendingPeople && !trending.isSignedIn",
          "group": "navigation@0"
        },
        {
          "command": "trending.signOut",
          "when": "view == trending.trendingPeople && trending.isSignedIn",
          "group": "navigation@0"
        },
        {
          "command": "trending.signIn",
          "when": "view == trending.chatPanel && !trending.isSignedIn",
          "group": "navigation@0"
        },
        {
          "command": "trending.signOut",
          "when": "view == trending.chatPanel && trending.isSignedIn",
          "group": "navigation@0"
        },
        {
          "command": "trending.myRepos.refresh",
          "when": "view == trending.myRepos",
          "group": "navigation"
        },
        {
          "command": "trending.trendingRepos.refresh",
          "when": "view == trending.trendingRepos",
          "group": "navigation"
        },
        {
          "command": "trending.trendingPeople.refresh",
          "when": "view == trending.trendingPeople",
          "group": "navigation"
        },
        {
          "command": "trending.feed.refresh",
          "when": "view == trending.feed",
          "group": "navigation"
        },
        {
          "command": "trending.inbox.refresh",
          "when": "view == trending.inbox",
          "group": "navigation"
        },
        {
          "command": "trending.notifications.refresh",
          "when": "view == trending.notifications",
          "group": "navigation"
        },
        {
          "command": "trending.notifications.markAllRead",
          "when": "view == trending.notifications",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "trending.openOnGithub",
          "when": "viewItem == myRepo",
          "group": "inline"
        },
        {
          "command": "trending.viewRepoDetail",
          "when": "viewItem == myRepo",
          "group": "1_actions"
        },
        {
          "command": "trending.unfollowUser",
          "when": "viewItem == friend",
          "group": "inline"
        },
        {
          "command": "trending.viewProfile",
          "when": "viewItem == friend",
          "group": "1_actions"
        },
        {
          "command": "trending.messageUser",
          "when": "viewItem == friend",
          "group": "1_actions"
        },
        {
          "command": "trending.likeEvent",
          "when": "viewItem == feedEvent",
          "group": "inline"
        },
        {
          "command": "trending.openOnGithub",
          "when": "viewItem == feedEvent",
          "group": "1_actions"
        },
        {
          "command": "trending.inbox.pinConversation",
          "when": "viewItem == conversation",
          "group": "1_actions"
        },
        {
          "command": "trending.inbox.markRead",
          "when": "viewItem == conversation",
          "group": "1_actions"
        },
        {
          "command": "trending.inbox.deleteConversation",
          "when": "viewItem == conversation",
          "group": "2_destructive"
        },
        {
          "command": "trending.notifications.markAllRead",
          "when": "viewItem == notification",
          "group": "1_actions"
        }
      ]
    },
    "keybindings": [
      {
        "command": "trending.browseTrendingRepos",
        "key": "ctrl+shift+g t",
        "mac": "cmd+shift+g t"
      },
      {
        "command": "trending.openInbox",
        "key": "ctrl+shift+g m",
        "mac": "cmd+shift+g m"
      },
      {
        "command": "workbench.view.extension.trendingSidebar",
        "key": "ctrl+shift+g g",
        "mac": "cmd+shift+g g"
      }
    ],
    "configuration": {
      "title": "Top GitHub Trending",
      "properties": {
        "trending.apiUrl": {
          "type": "string",
          "default": "https://api-dev.gitstar.ai/api/v1",
          "description": "API base URL"
        },
        "trending.wsUrl": {
          "type": "string",
          "default": "https://ws-dev.gitstar.ai",
          "description": "WebSocket server URL"
        },
        "trending.githubClientId": {
          "type": "string",
          "default": "Ov23liXf7KFWwKzcOHE0",
          "description": "GitHub OAuth App Client ID for device flow authentication"
        },
        "trending.trendingPollInterval": {
          "type": "number",
          "default": 300000,
          "description": "Trending data poll interval in ms (default: 5 min)"
        },
        "trending.feedPollInterval": {
          "type": "number",
          "default": 120000,
          "description": "Feed poll interval in ms (default: 2 min)"
        },
        "trending.presenceHeartbeat": {
          "type": "number",
          "default": 60000,
          "description": "Presence heartbeat interval in ms (default: 1 min)"
        },
        "trending.showMessageNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code notification popup for new messages"
        },
        "trending.messageSound": {
          "type": "boolean",
          "default": false,
          "description": "Play sound when receiving messages"
        },
        "trending.debugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Write chat logs to output channel"
        }
      }
    }
  },
  "scripts": {
    "vscode:uninstall": "node ./uninstall.js",
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vscode-test",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22",
    "@types/vscode": "^1.100.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "mocha": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.10",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "marked": "^17.0.5",
    "socket.io-client": "^4.8.0"
  }
}
