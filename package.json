{
  "name": "gitchat",
  "displayName": "GitChat — Team Chat Inside Your IDE",
  "description": "Chat with contributors, repo owners, and dev communities — without leaving your editor. No alt-tab. No context-switching.",
  "version": "1.0.1",
  "publisher": "Gitchat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitchatSH/gitchat_extension"
  },
  "homepage": "https://gitchat.sh",
  "qna": "https://github.com/GitchatSH/gitchat_extension/issues",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "github",
    "trending",
    "repositories",
    "developers",
    "social",
    "collaboration",
    "chat",
    "open-source",
    "cursor",
    "windsurf",
    "networking",
    "messaging",
    "community"
  ],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:trending.welcome",
    "onView:trending.explore",
    "onCommand:trending.signIn",
    "onCommand:trending.messageUser",
    "onCommand:trending.createGroup",
    "onCommand:trending.newChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "trending.signIn",
        "title": "Sign In with GitHub",
        "icon": "$(sign-in)",
        "category": "Trending"
      },
      {
        "command": "trending.signOut",
        "title": "Sign Out",
        "icon": "$(sign-out)",
        "category": "Trending"
      },
      {
        "command": "trending.userMenu",
        "title": "Account",
        "icon": "$(account)",
        "category": "Trending"
      },
      {
        "command": "trending.viewMyProfile",
        "title": "View My Profile",
        "category": "Trending"
      },
      {
        "command": "trending.messageUser",
        "title": "Message @user",
        "icon": "$(comment-discussion)",
        "category": "Trending"
      },
      {
        "command": "trending.openOnGithub",
        "title": "Open on GitHub",
        "icon": "$(link-external)"
      },
      {
        "command": "trending.createGroup",
        "title": "Create Group Chat",
        "icon": "$(organization)",
        "category": "Trending"
      },
      {
        "command": "trending.openChat",
        "title": "Open Chat"
      },
      {
        "command": "trending.copyInviteLink",
        "title": "Copy Invite Link",
        "icon": "$(link)",
        "category": "Trending"
      },
      {
        "command": "trending.copyProfileBadge",
        "title": "Copy Profile Badge for README",
        "icon": "$(shield)",
        "category": "Trending"
      },
      {
        "command": "trending.joinGroupByLink",
        "title": "Join Group by Invite Link",
        "icon": "$(link)",
        "category": "Trending"
      },
      {
        "command": "trending.openChannel",
        "title": "Open Repo Channel",
        "category": "Gitchat"
      },
      {
        "command": "trending.newChat",
        "title": "New Message",
        "category": "Trending",
        "icon": "$(comment-discussion)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trendingSidebar",
          "title": "GitChat",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "trendingSidebar": [
        {
          "id": "trending.welcome",
          "name": "",
          "type": "webview",
          "visibility": "visible",
          "when": "!trending.isSignedIn"
        },
        {
          "id": "trending.explore",
          "name": "",
          "type": "webview",
          "visibility": "visible",
          "when": "trending.isSignedIn"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "trending.signIn",
          "when": "view == trending.explore && !trending.isSignedIn",
          "group": "navigation@0"
        },
        {
          "command": "trending.newChat",
          "when": "view == trending.explore && trending.isSignedIn",
          "group": "navigation@1"
        },
        {
          "command": "trending.userMenu",
          "when": "view == trending.explore && trending.isSignedIn",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "workbench.view.extension.trendingSidebar",
        "key": "ctrl+shift+g g",
        "mac": "cmd+shift+g g"
      }
    ],
    "configuration": {
      "title": "Top GitHub Trending",
      "properties": {
        "trending.apiUrl": {
          "type": "string",
          "default": "https://api-dev.gitstar.ai/api/v1",
          "description": "API base URL"
        },
        "trending.wsUrl": {
          "type": "string",
          "default": "https://ws-dev.gitstar.ai",
          "description": "WebSocket server URL"
        },
        "trending.githubClientId": {
          "type": "string",
          "default": "Ov23liXf7KFWwKzcOHE0",
          "description": "GitHub OAuth App Client ID for device flow authentication"
        },
        "trending.presenceHeartbeat": {
          "type": "number",
          "default": 60000,
          "description": "Presence heartbeat interval in ms (default: 1 min)"
        },
        "trending.showMessageNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code notification popup for new messages"
        },
        "trending.messageSound": {
          "type": "boolean",
          "default": false,
          "description": "Play sound when receiving messages"
        },
        "trending.debugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Write chat logs to output channel"
        }
      }
    }
  },
  "scripts": {
    "vscode:uninstall": "node ./uninstall.js",
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vscode-test",
    "pretest": "npm run compile",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22",
    "@types/vscode": "^1.100.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "husky": "^9.1.7",
    "mocha": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.10",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "marked": "^17.0.5",
    "socket.io-client": "^4.8.0"
  }
}
